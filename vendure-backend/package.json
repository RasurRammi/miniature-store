{
  "name": "vendure-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:server": "ts-node ./src/index.ts",
    "dev:worker": "ts-node ./src/index-worker.ts",
    "dev:dashboard": "vite --clearScreen false",
    "dev": "concurrently --kill-others npm:dev:*",
    "build": "tsc",
    "build:dashboard": "vite build",
    "start:server": "node ./dist/index.js",
    "start:worker": "node ./dist/index-worker.js",
    "start": "concurrently npm:start:*",
    "codegen": "graphql-codegen --config codegen.ts",

    "migration:generate": "vendure migrate generate",
    "migration:run": "vendure migrate run",
    "migration:revert": "vendure migrate revert"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1005.0",
    "@aws-sdk/lib-storage": "^3.1005.0",
    "@vendure/asset-server-plugin": "3.5.5",
    "@vendure/core": "3.5.5",
    "@vendure/dashboard": "3.5.5",
    "@vendure/email-plugin": "3.5.5",
    "@vendure/graphiql-plugin": "3.5.5",
    "dotenv": "17.3.1",
    "graphql": "^16.13.1",
    "pg": "8.20.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "6.1.3",
    "@vendure/cli": "3.5.5",
    "concurrently": "9.2.1",
    "ts-node": "10.9.2",
    "typescript": "^5.8.2"
  }
}
